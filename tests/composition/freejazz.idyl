// ═══════════════════════════════════════════════════════════════════════════
// freejazz.idyl — free-jazz / Coltrane-style solo generator
// ─────────────────────────────────────────────────────────────────────────
// Generates trigger streams and pitch/dynamic data for expressive melodic
// improvisation. Designed for electronic music: wire the outputs into your
// instrument functions (grainsharp, vapordream, purecut, etc.).
//
// Requires: stdlib, music (import them before or in the same file).
//
// Quick-start template:
//
//   trig = jazz_density(peak_rate=18, phrase_ms=7000)
//   deg  = phrase_walk(trig, lo=0, hi=13, flip_prob=0.22, leap_prob=0.12)
//   oct  = octave_voice(trig, min_oct=-1, max_oct=1)
//   amp  = jazz_amp(lo_amp=mp, hi_amp=fff, phrase_ms=7000)
//   dur  = jazz_dur(trig, short_ms=60, long_ms=400)
//   freq = mtof(tune(a3 + oct, dorian, deg, just))
//   grainsharp(trig, freq, amp=amp, duration=dur, ch=1)
//
// TERNARY REMINDER (idyl): (cond) ? option0; option1
//   cond = 0 → option0 (the "false/do-nothing" branch)
//   cond = 1 → option1 (the "do-it" branch)
// ═══════════════════════════════════════════════════════════════════════════

import("stdlib")
import("music")


// ── §1  RHYTHM GENERATORS ─────────────────────────────────────────────────
// All return a trigger stream.  Wire directly as the `trig` input to melodic
// generators and instrument functions.


// breathing_rhythm — probabilistic triggers with sine-modulated density.
// Mimics the inhale / exhale of a live improviser: sparse → dense → sparse.
// base_rate   : avg triggers / sec at rest.
// breath_freq : speed of the breathing cycle (default ≈ 0.12 Hz → 8 s cycle).
// swell       : density peak = base_rate × (0.3 + swell).
breathing_rhythm(base_rate=8, breath_freq=0.12hz, swell=2.5, dt=10ms) = trig |> {
    init: { trig = _ }
    breath  = pos(sine(breath_freq, dt=dt))
    density = base_rate * (0.3 + breath * swell)
    trig    = trigger(rnd() < density * dt / 1000)
}

// sheets_rhythm — Coltrane "sheets of sound": dense bursts separated by rest.
// density  : triggers / sec during a burst.
// burst_ms : how long each dense burst lasts.
// rest_ms  : silent gap between bursts.
sheets_rhythm(density=24, burst_ms=600, rest_ms=300, dt=10ms) = trig |> {
    init: { phase = 0; trig = _ }
    phase = fmod(phase + dt, burst_ms + rest_ms)
    trig  = trigger(rnd() < (phase < burst_ms) * density * dt / 1000)
}

// sparse_rhythm — slow gestural triggers, wide spaces between notes.
// Useful for lyrical statements, endings, or "waiting" moments in a solo.
// rate : avg triggers / sec (typically 1–4).
sparse_rhythm(rate=2, dt=10ms) = trig |> {
    init: { trig = _ }
    trig = trigger(rnd() < rate * dt / 1000)
}

// jazz_density — phrase-arc trigger: starts near-silent, peaks at phrase_ms/2,
// returns to silence.  The arc is a half-sine (0 → 1 → 0 over phrase_ms).
// peak_rate : triggers / sec at the climax.
jazz_density(peak_rate=18, phrase_ms=6000, dt=10ms) = trig |> {
    init: { phase = 0; trig = _ }
    phase   = fmod(phase + dt, phrase_ms)
    arc     = sin(phase / phrase_ms * pi)
    density = peak_rate * (0.04 + arc * 0.96)
    trig    = trigger(rnd() < density * dt / 1000)
}


// ── §2  MELODIC GENERATORS ────────────────────────────────────────────────
// All are trigger-driven: they compute a new value on each trigger.
// Return a scale-degree integer (0-based index into any scale flow).
// Turn into frequency with:  mtof(tune(root, scale, degree, temperament))


// phrase_walk — directed random walk on scale degrees.
// Maintains a direction (±1) that occasionally flips (flip_prob).
// Occasionally substitutes a large leap (5–9 degrees) for a step (leap_prob).
// Inspired by Coltrane's motivic leaps and sudden register shifts.
//
// lo / hi    : degree range — 0..13 spans two heptatonic octaves.
// step       : max step size for normal motion (degrees per note).
// flip_prob  : probability of reversing direction on each note.
// leap_prob  : probability of a large leap instead of a normal step.
phrase_walk(trig!, lo=0, hi=13, step=2, flip_prob=0.2, leap_prob=0.1) = deg |> {
    init: {
        deg = 7
        dir = 1
    }
    should_flip = trigger(rnd() < flip_prob)
    dir  = (should_flip) ? dir; dir * -1
    is_leap = trigger(rnd() < leap_prob)
    move = (is_leap) ? dir * rndi(1, step); dir * rndi(5, 9)
    deg  = clamp(deg + move, lo, hi)
}

// run_walk — scalar runs (ascending or descending) that periodically flip.
// Produces ascending / descending cascades — "sheets of scale".
// run_len  : notes per run before a possible direction change.
// flip_prob: probability of flipping direction at the end of a run.
run_walk(trig!, lo=0, hi=13, run_len=4, flip_prob=0.3) = deg |> {
    init: {
        deg       = 6
        dir       = 1
        remaining = 4
    }
    remaining = max(remaining - 1, 0)
    end_run   = trigger((remaining <= 0) * (rnd() < flip_prob))
    dir       = (end_run) ? dir; dir * -1
    remaining = (end_run) ? remaining; run_len
    deg       = clamp(deg + dir, lo, hi)
}

// free_walk — fully random degree selection, ignores direction.
// Useful for atonal "outside" moments or transition passages.
free_walk(trig!, lo=0, hi=13) = deg |> {
    init: { deg = 7 }
    deg = rndi(lo, hi)
}

// octave_voice — slowly drifts the octave register across a solo.
// Returns a semitone offset in steps of 12 (e.g. -12, 0, +12).
// drift_prob : probability of shifting ±1 octave on each note.
// min_oct / max_oct : octave range in octave units (not semitones).
octave_voice(trig!, min_oct=-1, max_oct=1, drift_prob=0.06) = oct_st |> {
    init: { oct = 0 }
    should_drift = trigger(rnd() < drift_prob)
    step         = (should_drift) ? 0; rndi(-1, 1)
    oct          = clamp(oct + step, min_oct, max_oct)
    oct_st       = oct * 12
}


// ── §3  PHRASE SHAPING ────────────────────────────────────────────────────
// dt-driven (run continuously).  Return modulation signals.


// phrase_arc — half-sine envelope over phrase_ms: 0 → 1 → 0.
// Return value: 0..1.  Modulate density, amplitude, register, anything that
// should build to a climax and release.  phrase_ms = total phrase length.
phrase_arc(phrase_ms=8000, dt=10ms) = arc |> {
    init: { phase = 0 }
    phase = fmod(phase + dt, phrase_ms)
    arc   = sin(phase / phrase_ms * pi)
}

// jazz_amp — phrase-arc amplitude, swells from lo_amp to hi_amp and back.
// Sync phrase_ms to jazz_density's phrase_ms for a coherent arc.
jazz_amp(lo_amp=mp, hi_amp=fff, phrase_ms=6000, dt=10ms) = amp |> {
    init: { phase = 0 }
    phase = fmod(phase + dt, phrase_ms)
    arc   = sin(phase / phrase_ms * pi)
    amp   = lo_amp + (hi_amp - lo_amp) * arc
}


// ── §4  NOTE DURATION & TENSION ───────────────────────────────────────────


// jazz_dur — trigger-driven note duration.
// Mostly short / staccato; long_prob fraction of notes are held long.
// short_ms: typical short-note duration range (half to 2.5×).
// long_ms : typical long-note duration range (0.4× to 1×).
jazz_dur(trig!, short_ms=60, long_ms=400, long_prob=0.15) = dur |> {
    init: { dur = 80 }
    is_long = trigger(rnd() < long_prob)
    dur     = (is_long) ? rnd(short_ms * 0.5, short_ms * 2.5); rnd(long_ms * 0.4, long_ms)
}

// outside_offset — chromatic displacement for "outside" approach tones.
// Returns 0 (in scale) or ±1 semitone (chromatic enclosure / blue note).
// Add to the result of tune(...) before passing to mtof().
// tension : probability of displacing by a half-step.
outside_offset(trig!, tension=0.15) = offset |> {
    init: { offset = 0 }
    go_out = trigger(rnd() < tension)
    offset = (go_out) ? 0; rndi(-1, 1)
}

// scale_mood — slowly cycles through four tonalities: dorian → whole_tone →
// diminished → bebop.  Returns an index 0..3 that you use to select the scale
// flow in your process.  change_prob controls how often the mood shifts.
//
//   mood = scale_mood(trig, change_prob=0.04)
//   scale = (mood) ? dorian; whole_tone; diminished; bebop
scale_mood(trig!, change_prob=0.04) = mood |> {
    init: { mood = 0 }
    change = trigger(rnd() < change_prob)
    mood   = (change) ? mood; int(fmod(mood + 1, 4))
}


// ─────────────────────────────────────────────────────────────────────────
// DEMO PROCESSES
// ─────────────────────────────────────────────────────────────────────────
// These print generated values so they run without Csound.
// Swap the print(...) line for your instrument call, e.g.:
//   grainsharp(trig, freq, amp=amp, duration=dur, ch=1)
//   vapordream(trig, freq, amp=amp, duration=dur)
//   purecut(trig,    freq, amp=amp, duration=dur, ch=rndi(1,2))
// ─────────────────────────────────────────────────────────────────────────


// Breathing solo — organic density, directed walk, dorian / just intonation.
// Sounds like a single voice improvising over modal harmony.
process fj_walk: {
    tempo(120bpm)
    trig = breathing_rhythm(base_rate=7, breath_freq=0.1hz, swell=3)
    deg  = phrase_walk(trig, lo=0, hi=13, step=3, flip_prob=0.22, leap_prob=0.12)
    oct  = octave_voice(trig, min_oct=-1, max_oct=1, drift_prob=0.07)
    amp  = jazz_amp(lo_amp=mp, hi_amp=fff, phrase_ms=7000)
    dur  = jazz_dur(trig, short_ms=60, long_ms=400)
    root = a3 + oct
    freq = mtof(tune(root, dorian, deg, just))
    // ── connect instrument here ──
    print("walk | deg:", deg, "note:", freq, "dur:", dur, "amp:", amp)
}

// Sheets solo — dense burst packets + ascending/descending runs.
// Two voices: slow (whole tone, dreamy) + fast (bebop, cutting).
process fj_sheets: {
    tempo(140bpm)
    ph    = phasor(4b)

    // Slow lyrical voice — whole tone, sheets bursts
    slow_trig = sheets_rhythm(density=14, burst_ms=800, rest_ms=500)
    slow_deg  = phrase_walk(slow_trig, lo=0, hi=11, step=2, flip_prob=0.18, leap_prob=0.2)
    slow_oct  = octave_voice(slow_trig, min_oct=0, max_oct=1, drift_prob=0.05)
    slow_amp  = jazz_amp(lo_amp=mp, hi_amp=ff, phrase_ms=9000)
    slow_dur  = jazz_dur(slow_trig, short_ms=80, long_ms=600, long_prob=0.25)
    slow_freq = mtof(tune(c3 + slow_oct, whole_tone, slow_deg, equal))

    // Fast cutting voice — bebop, scalar runs, tight staccato
    fast_trig = euclid(5, 8, phase_in=ph)
    fast_deg  = run_walk(fast_trig, lo=0, hi=13, run_len=5, flip_prob=0.28)
    fast_oct  = octave_voice(fast_trig, min_oct=0, max_oct=2, drift_prob=0.04)
    fast_chrom = outside_offset(fast_trig, tension=0.18)
    fast_dur  = jazz_dur(fast_trig, short_ms=40, long_ms=200, long_prob=0.08)
    fast_freq = mtof(tune(c3 + fast_oct, bebop, fast_deg, equal) + fast_chrom)

    amp = jazz_amp(lo_amp=mf, hi_amp=fff, phrase_ms=8000)

    // ── connect instruments here ──
    print("slow | freq:", slow_freq, "dur:", slow_dur)
    print("fast | freq:", fast_freq, "dur:", fast_dur, "amp:", amp)
}

// Free solo — phrase-arc density, mood-shifting scales, chromatic outside notes.
// Single voice that cycles through four tonal moods autonomously.
process fj_free: {
    tempo(100bpm)

    trig  = jazz_density(peak_rate=20, phrase_ms=9000)
    deg   = phrase_walk(trig, lo=0, hi=14, step=2, flip_prob=0.3, leap_prob=0.2)
    oct   = octave_voice(trig, min_oct=-1, max_oct=2, drift_prob=0.08)
    mood  = scale_mood(trig, change_prob=0.05)
    chrom = outside_offset(trig, tension=0.2)
    amp   = jazz_amp(lo_amp=p, hi_amp=fff, phrase_ms=9000)
    dur   = jazz_dur(trig, short_ms=50, long_ms=500, long_prob=0.18)

    root  = fs3 + oct
    // Select scale by mood index: 0=dorian  1=whole_tone  2=dim_half  3=bebop
    scale_note = (mood) ? tune(root, dorian, deg, just); tune(root, whole_tone, deg, equal); tune(root, dim_half, deg, equal); tune(root, bebop, deg, equal)
    freq = mtof(scale_note + chrom)

    // ── connect instrument here ──
    print("free | mood:", mood, "freq:", freq, "dur:", dur, "amp:", amp)
}
