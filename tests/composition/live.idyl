import("stdlib")
import("music")
module("csound")

cs = cs_open("main.csd")

flow melody = {
	rhythm: [ ! , ! , _ ]
	chn: [1, 2]
	note on rhythm: [0, 1, 2, 3, 4, 5, 6, 7]
}

flow stuff = {
	rhythm: [ ! , ! , _ ,_ , _, ! ,  _ , ! ,  ! , _ , ! , !]
	degree: [0, 1,5, 3, 6, 0,  3, 7 , 0,  2, 5, 3, 0]
	chn: [1, 2]
}

rndt(rangemin, rangemax, dt = 500ms) = rnd(rangemin, rangemax)

process test: {
	mel = melody[metro(0.25b)]
	scale = minor
	on mel.rhythm: {
		print("hello")
		cs_note(cs, "sine", 5s, 0.1, tune(c4, scale, mel.note, meantone), mel.chn)
	}
}

process test2: {
	mel = melody[metro(4b)]
	base = c3
	scale = mixolydian
	on mel.rhythm: {
		print("hello")
		index = floor(rnd(0, 7))
		cs_note(cs, "sine", 10s, 0.3, tune(base, scale, index, just), mel.chn)
		index = floor(rnd(0, 7))
		cs_note(cs, "sine", 10s, 0.3, tune(base + 12, scale, index, just), mel.chn)
		index = floor(rnd(0, 7))
		@(0.25b) : {
			cs_note(cs, "sine", 10s, 0.3, tune(base + 24, scale, index, just), mel.chn)
		}
	}
}

process test3: {
	mel = stuff[metro(2b)]
	deg2 = stuff.degree[metro(2b)]
	cond = rndt(0, 1, 0.5b)
	base = ( cond > 0.25) ? d5; d3
	scale = mixolydian
	on mel.rhythm: {
		print("hello")
		cs_note(cs, "sine", 10s, 0.3, tune(base, scale, mel.degree, just), mel.chn)
		@(0.25b) : {
			cs_note(cs, "sine", 10s, 0.3, tune(base, scale, deg2, just), mel.chn)
		}
	}
}


flow arps = {
	degree: [ 1, 2, 3 |3| , 13, 8]
	chn: [1, 2]
}

flow arps2 = {
	degree: [ [1, 2, 3] |3| , 13, 8]
	chn: [1, 2]
}


flow bases = [c3, g3, d3, f4] 

process test4: {
	clk = clock(120bpm)
	base = c3 //bases[metro(8b)] 
	on metro(clk(7*0.5b) ): {
		print("metro >> ") 
		each n in len(arps), dt= clk(0.5b): {
			arp = arps[n] 
			print(arp.degree)
			arp2 = arps[-n] 
			//print("arp", n)
			cs_note(cs, "sine", 1s, 0.3, tune(base, melodic_minor, arp.degree, just), arp.chn)
			//cs_note(cs, "sine", 10s, 0.3, tune(base, melodic_minor, arp2.degree, just), arp2.chn)

		}
	}

	@(3s): {
		stop test4
	} 
}


process test5: {
	clk = clock(120bpm)
	base = c3 //bases[metro(8b)] 
	on metro(clk(11*0.5b) ): {
		print("metro >> ") 
		each n in len(arps2), dt= clk(0.5b): {
			arp = arps2[n] 
			print(arp.degree)
			//arp2 = arps[-n] 
			//print("arp", n)
			cs_note(cs, "sine", 1s, ff, tune(base, melodic_minor, arp.degree, just), arp.chn)
			//cs_note(cs, "sine", 10s, 0.3, tune(base, melodic_minor, mel.degree, just), arp2.chn)

		}
	}
	@(3s): {
		pause
	} 

	@(5s): {
		resume
	}
	@(6s): {

		pause
	}

	@(7s): {
		resume
	}	


}

process test6: {
	osc = pos(lfo(0.1hz, dt=50ms)) * 200 + 300 
	tempo(as_bpm(osc / 5) )
	on metro( 2.5b ): {
		print("metro >> ") 
		each n in 5, dt= 0.5b: {
			arp = arps[n] 
			print("arp", n)
			print(ppp)
			cs_note(cs, "sine", 10s, f, tune(c4, melodic_minor, arp.degree, just), arp.chn)
			arp2 = arps[-n] 
			cs_note(cs, "sine", 10s, f, tune(c1, melodic_minor, arp2.degree, just), arp2.chn)

		}
	}
}

flow cnt = [1 , 2, 3, 4, 5] 
process test7: {
	m = metro(0.5s)
	print(cnt[metro(0.5s)])
	print(cnt[metro(0.5s)], cnt[m])
}


process tempotest: {
	a = metro(1b) 
	on(a): {
		cs_note(cs, "sine", 10s, f, tune(c4, melodic_minor, 0, just), 2)
	}
}
process tempotest2: {
	a = metro(1b) 
	on(a): {
		cs_note(cs, "sine", 10s, f, tune(c4, melodic_minor, 3, just), 1)
	}
}
