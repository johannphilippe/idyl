}

flow cnt = [1 , 2, 3, 4, 5] 
process test7: {
	m = metro(0.5s)
	print(cnt[metro(0.5s)])
	print(cnt[metro(0.5s)], cnt[m])
}


clk = clock(160bpm)

process tempotest: {
	a = sync(clk,  1b ) 
	on(a): {
		cs_note(cs, "sine", 1s, f, tune(c4, melodic_minor, 0, just), 2)
	}
}
process tempotest2: {
	a = sync(clk, clk(1b) )
	on(a): {
		cs_note(cs, "sine", 1s, f, tune(c4, melodic_minor, 3, just), 1)
	}
}

process tempotest3: {
	a = sync(clk, 2b) //sync(clk, clk(1b) )
	on(a): {
		cs_note(cs, "sine", 1s, f, tune(c4, melodic_minor, 3, just), 1)
	}
}

process euclidtest: {
	phase = phasor(clk, 2b) 
	a = euclid(3, 8, phase_in = phase)
	on(a): {
		cs_note(cs, "sine", 1s, f, tune(c4, melodic_minor, 5, just), 2)
	}
}

process euclid2: {
	phase = phasor(clk, 2b) 
	b = euclid(5, 8, phase_in=phase)
	on(b): {
		cs_note(cs, "sine", 1s, f, tune(c4, melodic_minor, 2, just), 1)
	}
}

process euc: {
	phase = phasor(clk, 4b) 
	c = euclid(3, 8, phase_in=phase)
	on(c): {
		cs_note(cs, "sine", 1s, fff, tune(c2, melodic_minor, -4, just), int(rnd(1, 2.99)))
	}
}
