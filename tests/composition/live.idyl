import("stdlib")
import("music")
module("csound")
module("midi")

cs = cs_open("main.csd")
fh = midi_out(2)
matrix = midi_out(3) 


flow mf = [1, 2, 3, 4, 5]

process checkflow: {
	a = mf[metro(0.5s)] 
	print(a) 
}

process choose_outputs: {
	r = cs_note(cs, "dusk", 0, 888 )

	each i in 4: {
		chan = int(rnd(1, 2.99))
		//chan = int(rnd(1, 8.99))
		cond = rnd(0, 1)
		print(i, chan, cond)
		r = (cond > 0.75) ? _ ; cs_note(cs, 888 , -1s, i + 1, chan)
		print(r)
	}
	stop
}


process scramble_mat: {
	each x in 16: {
		each y in 16: {
			r = (rnd(0, 1) > 0.9) ? midi_note_off(matrix, 2, x, y) ; midi_note_on(matrix, 2, x, y) 
		}
	}
	stop
	
}

process reset_mat: {
	each x in 16: {
		each y in 16: {
			midi_note_off(matrix, 2, x, y)
		}
	}
	stop 
}

flow dynamicmel(deg) = [ tune(c2, minor, deg, just), tune(d3, major, deg, just) ]


fh2_note(spike!, ch, note, vel) = midi_note_on(fh, ch, midinote, vel)
|> {
	pb = (note - int(note)) * 256 
	midinote = int(note) 
	midi_pitch_bend(fh, ch, pb)
	
}

process miditest: {
	a = metro(.5b)
	mel = melody[a] 
	change = counter(3b)
	print(change)
	note = dynamicmel(mel.note)[change]
	on(mel.rhythm): {
		print(note)
		//print(mel.note)
		//midi_note_on(fh, 1, note, 100) 
		fh2_note(!, 1, note, 100)
	}	
}

process pr: {
	m = melody[metro(1b)] 
	print(m.note)
}

flow melody = {
	rhythm: [ ! , ! , ! ]
	chn: [1, 2]
	note: [0, 1, 2, 3, 4, 5, 6, 7]
}

flow stuff = {
	rhythm: [ ! , ! , _ ,_ , _, ! ,  _ , ! ,  ! , _ , ! , !]
	degree: [0, 1,5, 3, 6, 0,  3, 7 , 0,  2, 5, 3, 0]
	chn: [1, 2]
}

rndt(rangemin, rangemax, dt = 500ms) = rnd(rangemin, rangemax)

process test: {
	mel = melody[metro(0.25b)]
	scale = minor
	on mel.rhythm: {
		print("hello")
		cs_note(cs, "sine", 5s, 0.1, tune(c4, scale, mel.note, meantone), mel.chn)
	}
}

process test2: {
	mel = melody[metro(4b)]
	base = c3
	scale = mixolydian
	on mel.rhythm: {
		print("hello")
		index = floor(rnd(0, 7))
		cs_note(cs, "sine", 10s, 0.3, tune(base, scale, index, just), mel.chn)
		index = floor(rnd(0, 7))
		cs_note(cs, "sine", 10s, 0.3, tune(base + 12, scale, index, just), mel.chn)
		index = floor(rnd(0, 7))
		@(0.25b) : {
			cs_note(cs, "sine", 10s, 0.3, tune(base + 24, scale, index, just), mel.chn)
		}
	}
}

process test3: {
	mel = stuff[metro(2b)]
	deg2 = stuff.degree[metro(2b)]
	cond = rndt(0, 1, 0.5b)
	base = ( cond > 0.25) ? d5; d3
	scale = mixolydian
	on mel.rhythm: {
		print("hello")
		cs_note(cs, "sine", 10s, 0.3, tune(base, scale, mel.degree, just), mel.chn)
		@(0.25b) : {
			cs_note(cs, "sine", 10s, 0.3, tune(base, scale, deg2, just), mel.chn)
		}
	}
}


flow arps = {
	degree: [ 1, 2, 3 |3| , 13, 8]
	chn: [1, 2]
}

flow arps2 = {
	degree: [ [1, 2, 3] |3| , 13, 8]
	chn: [1, 2]
}


flow bases = [c3, g3, d3, f4] 

