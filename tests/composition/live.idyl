process euclidtest: {
	phase = phasor(clk, 4b) 
	a = euclid(5, 8, phase_in = phase)
	on(a): {
		cs_note(cs, "sine", .5s, f, tune(c4, melodic_minor, 2, just), 2)
	}
}

process euclid2: {
	phase = phasor(clk, 4b) 
	b =  euclid(5, 8, phase_in=phase)
	on(b): {
		cs_note(cs, "sine", .5s, f, tune(c4, melodic_minor, 6, just), 1)
	}
}

process euc: {
	tempo(clk, 120bpm)
	phase = phasor(clk, 4b) 
	c = euclid(5, 8, phase_in=phase)
	on(c): {
		cs_note(cs, "sine", .5s, fff, tune(c2, melodic_minor, 0, just), int(rnd(1, 2.99)))
	}
}
