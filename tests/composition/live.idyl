	}	


}

process test6: {
	osc = pos(lfo(0.1hz, dt=50ms)) * 200 + 300 
	tempo(as_bpm(osc / 5) )
	on metro( 2.5b ): {
		print("metro >> ") 
		each n in 5, dt= 0.5b: {
			arp = arps[n] 
			print("arp", n)
			print(ppp)
			cs_note(cs, "sine", 10s, f, tune(c4, melodic_minor, arp.degree, just), arp.chn)
			arp2 = arps[-n] 
			cs_note(cs, "sine", 10s, f, tune(c1, melodic_minor, arp2.degree, just), arp2.chn)

		}
