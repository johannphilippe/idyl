import("stdlib")
import("music")
module("csound")

cs = cs_open("main.csd")

flow melody = {
	rhythm: [ ! , ! , _ ]
	chn: [1, 2]
	note on rhythm: [0, 1, 2, 3, 4, 5, 6, 7]
}

flow stuff = {
	rhythm: [ ! , ! , _ ,_ , _, ! ,  _ , ! ,  ! , _ , ! , !]
	degree: [0, 1,5, 3, 6, 0,  3, 7 , 0,  2, 5, 3, 0]
	chn: [1, 2]
}

rndt(rangemin, rangemax, dt = 500ms) = rnd(rangemin, rangemax)

process test: {
	mel = melody[metro(0.25b)]
	scale = minor
	on mel.rhythm: {
		print("hello")
		cs_note(cs, "sine", 5s, 0.1, tune(c4, scale, mel.note, meantone), mel.chn)
	}
}

process test2: {
	mel = melody[metro(4b)]
	base = c3
	scale = mixolydian
	on mel.rhythm: {
		print("hello")
		index = floor(rnd(0, 7))
		cs_note(cs, "sine", 10s, 0.3, tune(base, scale, index, just), mel.chn)
		index = floor(rnd(0, 7))
		cs_note(cs, "sine", 10s, 0.3, tune(base + 12, scale, index, just), mel.chn)
		index = floor(rnd(0, 7))
		@(0.25b) : {
			cs_note(cs, "sine", 10s, 0.3, tune(base + 24, scale, index, just), mel.chn)
		}
	}
}

process test3: {
	mel = stuff[metro(2b)]
	deg2 = stuff.degree[metro(2b)]
	cond = rndt(0, 1, 0.5b)
	base = ( cond > 0.25) ? d5; d3
	scale = mixolydian
	on mel.rhythm: {
		print("hello")
		cs_note(cs, "sine", 10s, 0.3, tune(base, scale, mel.degree, just), mel.chn)
		@(0.25b) : {
			cs_note(cs, "sine", 10s, 0.3, tune(base, scale, deg2, just), mel.chn)
		}
	}
}


flow arps = {
	degree: [0, 3,  7, 10, 12]
	chn: [1, 2]
}

process test4: {
	clk = clock(120bpm)
	on metro(clk(2.5b) ): {
		print("metro >> ") 
		each n in 5, dt= clk(0.5b): {
			arp = arps[n] 
			arp2 = arps[-n] 
			print("arp", n)
			cs_note(cs, "sine", 10s, 0.3, tune(g3, melodic_minor, arp.degree, just), arp.chn)
			cs_note(cs, "sine", 10s, 0.3, tune(d2, melodic_minor, arp2.degree, just), arp2.chn)

		}
	}
}

process test5: {
	on metro( 2.5b ): {
		print("metro >> ") 
		each n in 5, dt= 0.5b: {
			arp = arps[n] 
			arp2 = arps[-n] 
			print("arp", n)
			cs_note(cs, "sine", 10s, 0.3, tune(g3, melodic_minor, arp.degree, just), arp.chn)
			cs_note(cs, "sine", 10s, 0.3, tune(d2, melodic_minor, arp2.degree, just), arp2.chn)

		}
	}
}
