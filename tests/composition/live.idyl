import("stdlib")
import("music")
module("csound")
module("midi")

cs = cs_open("main.csd")
matrix = midi_out(2) 
fh = midi_out(3)

NCH = 2


/*
	Deux idées : 
		- un process qui accompagne le "test" en faisant du montage de synthé modulaire 
		- Quelque chose de numérique qui amplifie la dimension rythmique & montage

	D'autres idées : 
		- utiliser lushpad pour un drone fixé (avec potentiellement d'autres choses dessus) 

		- Une config ou le synthé part en dronish texturé (avec les wavefolding, et des déphasages) 
	
*/


deepkick(spike!, amp = mp) = cs_note(cs, "deepkick", 1s, amp, 500, 20, 0.05)
dirtykick(spike!, amp=mp) = cs_note(cs, "dirtykick", 1s, amp, 300, 20, 8)

// ── Smooth harmonic synth — long just-intonation chords ──────────────────────
// lushpad(trig!, freq_hz, dur, amp, ch, brightness)
// brightness: 0=dark/warm  0.5=neutral  1=open/bright
lushpad(spike!, freq, duration=8s, amp=f, ch=1, bright=0.5) =
    cs_note(cs, "lushpad", duration, amp, freq, ch, bright)

// ── IDM sharp synthesizers ────────────────────────────────────────────────────
// grainsharp — noisy, gritty, FM+noise
grainsharp(spike!, freq, duration=0.3s, amp=f, ch=1) =
    cs_note(cs, "grainsharp", duration, amp, freq, ch)

// metalsharp — metallic, inharmonic FM ring
metalsharp(spike!, freq, duration=0.5s, amp=f, ch=1) =
    cs_note(cs, "metalsharp", duration, amp, freq, ch)

// purecut — sine-ish, clean, very precise attack click
purecut(spike!, freq, duration=0.3s, amp=f, ch=1) =
    cs_note(cs, "purecut", duration, amp, freq, ch)

// ── Vaporwave sounds — always stereo (outputs to ch 1+2) ─────────────────────
// vaporpad — lush chorus pad, very slow attack, deep reverb
vaporpad(spike!, freq, duration=12s, amp=f) =
    cs_note(cs, "vaporpad", duration, amp, freq, 1)

// vapordream — retro-piano attack into dreamy reverb sustain
vapordream(spike!, freq, duration=10s, amp=f) =
    cs_note(cs, "vapordream", duration, amp, freq, 1)

whisperer(spike!, freq=200hz, duration=10s, amp=f, modspeed=0.4) =  
    cs_note(cs, "whisperer", duration, freq, amp, modspeed)


flow whisper = {
	base: [c4] 
	deg: 	  [0, 2, -2, 4]
	duration: [8b, 16b, 8b, 12b ] 
}


process whisp: {
	tempo(60)
	speed = whisper.duration[0]
	m = metro(speed)
	r = rcounter(m, _)
	

	w = whisper[m]
	on(m): {
		speed = whisper.duration[r+1]
		print("speed", speed)
	}	
	speed = whisper.duration[!]
	
	whisperer(m, freq=mtof(tune(w.base, minor, w.deg, just)), duration= w.duration * 2, amp=f, modspeed = rnd(0.3, 0.6)) 

}


flow superchord = {
	first: [1, 2, 6, 8]
	second: [3, 4, 3, 1, 7]
	third: [5, 6, 7, 2, 8, 11]
}

// Resettable counter — counts up on `incr`, resets to 0 on `reset`.
rrcounter(incr!, reset!, dt=10ms) = count |> {
    init: {count = 0}
    count = (reset) ? count + 1; 0
}

// Resettable counter — counts up on `incr`, resets to 0 on `reset`.
nodtrrcounter(incr!, reset!) = count |> {
    init: {count = 0}
    count = (reset) ? count + 1; 0
}

flow sc = [1, 2, 6]
flow scc = {
	first: [1, 2, 6, 8]
	second: [3, 4, 3, 1, 7]
	third: [5, 6, 7, 2, 8, 12, 10]
}

process lush: {
	tempo(120bpm)
	c = sync(8b)
	print(c)
	index = rcounter(sync(8b), _)
	fl =  scc[c] //superchord[index]
	print(index, fl)
	lushpad(c, mtof(tune(c3, dorian, fl.third, just)), amp=fff, ch=rndi(1, NCH))
	lushpad(c, mtof(tune(c3, dorian, fl.first, just)), amp = fff, ch=rndi(1, NCH))
	lushpad(c, mtof(tune(c5, dorian, fl.second, just)), amp = mf, ch = rndi(1, NCH))
	lushpad(c, mtof(tune(c6, dorian, fl.third, just)), amp = mf, ch = rndi(1, NCH))
}





process test: {
	tempo(120bpm)
	//lushpad(!, 300, amp = fff)
	a = sync(4b)
	b = sync(2b)
	c = sync(8b)
	//purecut(a, mtof(tune(c5, minor, 8, just)), amp=fff, ch=2)
	//purecut(b, mtof(tune(c7, minor, 2, just)), amp=fff, ch=1)
	print("mf: ", mf)

	index = nodtrrcounter(sync(8b), _)
	fl = superchord[index]
	ph = phasor(2b)
	vapordream(euclid(3, 8, phase_in=ph), mtof(tune(a3, dorian, fl.second, just)), amp=fff, duration=.1s)
	vapordream(euclid(3, 8, phase_in=ph), mtof(tune(a3, dorian, fl.third, just)), amp=fff, duration=.1s)
	print(fl.first, fl.second, fl.third) 
