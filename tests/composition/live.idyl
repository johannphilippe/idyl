	clk = clock(120bpm)
	base = c3 //bases[metro(8b)] 
	on metro(clk(7*0.5b) ): {
		print("metro >> ") 
		each n in len(arps), dt= clk(0.5b): {
			arp = arps[n] 
			print(arp.degree)
			arp2 = arps[-n] 
			//print("arp", n)
			cs_note(cs, "sine", 1s, fff, tune(base, melodic_minor, arp.degree, just), arp.chn)
			//cs_note(cs, "sine", 10s, 0.3, tune(base, melodic_minor, arp2.degree, just), arp2.chn)

		}
	}

}


process test5: {
	clk = clock(120bpm)
	base = c3 //bases[metro(8b)] 
	on metro(clk(11*0.5b) ): {
		print("metro >> ") 
		each n in len(arps2), dt= clk(0.5b): {
			arp = arps2[n] 
			print(arp.degree)
			//arp2 = arps[-n] 
			//print("arp", n)
