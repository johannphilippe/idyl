}

flow melody = {
	rhythm: [ ! , ! , _ ]
	chn on rhythm: [1, 2]
	note on rhythm: [0, 1, 2, 3, 4, 5, 6, 7]
}

flow stuff = {
	rhythm: [ ! , ! , _ ,_ , _, ! ,  _ , ! ,  ! , _ , ! , !]
	degree: [0, 1,5, 3, 6, 0,  3, 7 , 0,  2, 5, 3, 0]
	chn: [1, 2]
}

rndt(rangemin, rangemax, dt = 500ms) = rnd(rangemin, rangemax)


process test2: {
	mel = melody[metro(4b)]
	base = c3
	scale = mixolydian
	on mel.rhythm: {
		print("hello")
		index = floor(rnd(0, 7))
		cs_note(cs, "sine", 10s, 0.3, tune(base, scale, index, just), mel.chn)
		index = floor(rnd(0, 7))
		cs_note(cs, "sine", 10s, 0.3, tune(base + 12, scale, index, just), mel.chn)
		index = floor(rnd(0, 7))
		@(0.25b) : {
			cs_note(cs, "sine", 10s, 0.3, tune(base + 24, scale, index, just), mel.chn)
		}
	}
}

process test3: {
	mel = stuff[metro(2b)]
	deg2 = stuff.degree[metro(2b)]
	cond = rndt(0, 1, 0.5b)
	base = ( cond > 0.25) ? d5; d3
	scale = mixolydian
	on mel.rhythm: {
		print("hello")
		cs_note(cs, "sine", 10s, 0.3, tune(base, scale, mel.degree, just), mel.chn)
		@(0.25b) : {
			cs_note(cs, "sine", 10s, 0.3, tune(base, scale, deg2, just), mel.chn)
		}
	}
}


