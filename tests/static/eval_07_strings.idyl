// eval_07_strings.idyl — string type tests

// String constant bindings
greeting = "hello world"
addr = "/osc/note"
full_addr = addr + "/velocity"
combined = "hello" + " " + "world"
coerced = "value: " + 42

process: {
    // Basic string literal
    print(greeting)

    // String concatenation
    print(combined)

    // String + number coercion
    print(coerced)

    // String comparison
    print("abc" == "abc")     // expect 1
    print("abc" != "xyz")     // expect 1
    print("abc" < "xyz")      // expect 1

    // String in variable binding
    print(addr)
    print(full_addr)
}
