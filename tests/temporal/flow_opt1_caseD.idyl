// Case D: direct temporal elements in a flow
// Each flow slot IS a temporal instance (sine/square).
// Indexing should return the current live output of each instance, not a snapshot.
import("stdlib")

flow oscs = [sine(1hz, dt=100ms), sine(3hz, dt=100ms)]

process: {
    m = metro(dt=300ms)
    // Values should change each tick (not always the same initial output)
    print(oscs[m])
}
