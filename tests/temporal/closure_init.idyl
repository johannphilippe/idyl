// A temporal function whose output IS a closure.
// make_adder(n) returns a function fn(x) = x + n.
// n is a parameter captured by reference (Option B): reads inst.params_ at call time.
make_adder(n, dt=100ms) = fn |>
{
    init: {
        fn(x) = x + n
    }
}

process: {
    add5 = make_adder(5)
    print(add5(10))
    print(add5(20))
}
