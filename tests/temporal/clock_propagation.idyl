// ── Clock hierarchy propagation test ────────────────────────────
// Verifies that tempo changes propagate through the clock tree

process: {
    // Setup: main=120, c1=60 (ratio 0.5), c2=90 (ratio 0.75)
    c1 = clock(60bpm)
    c2 = clock(90bpm)

    // c3 is child of c1 at 30bpm (ratio to c1 = 30/60 = 0.5)
    c3 = clock(30bpm, parent=c1)

    print("initial c1:", bpm(c1), "c2:", bpm(c2), "c3:", bpm(c3))

    // Change main to 240bpm:
    //   c1 = 240 * 0.5  = 120
    //   c2 = 240 * 0.75 = 180
    //   c3 = 120 * 0.5  = 60  (child of c1, not main)
    tempo(240bpm)
    print("after main→240: c1:", bpm(c1), "c2:", bpm(c2), "c3:", bpm(c3))

    // Set c1 directly to 60bpm → c3 should become 60 * 0.5 = 30
    tempo(c1, 60bpm)
    print("after c1→60: c1:", bpm(c1), "c3:", bpm(c3))

    // Free-running clock: unaffected by main
    c_free = clock(100bpm, parent=0)
    tempo(300bpm)
    print("after main→300: main:", tempo(), "c_free:", bpm(c_free))
}
