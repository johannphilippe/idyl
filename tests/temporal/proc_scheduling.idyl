
cnt(limit, dt=300ms) = cnt
|> {
    init: {cnt = 0}
    cnt = cnt + 1 
    emit killsig = (cnt == limit) ? _; !
}

process a: {
    r = cnt(5)
    print(r)
    catch r::killsig: {
        print("Ending process a, starting b")
        stop a
        start b
    }
}

process b: {
    r = cnt(10)
    print(r)
    catch r::killsig: {
        print("Ending process b")
        stop 
    }
}