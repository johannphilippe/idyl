module("osc")
import("stdlib")

addr = "127.0.0.1"
port = 9000
handle = osc_out(addr, port)

flow melody = {
    notes: [50, 53, 60, 65, 47, 33, 60]
    rhythm: [!, !, _, !, !, !, _, _, _, !, _, !, !, !, !, !]
}

process: {
    met = metro(dt = 0.2s)
    print(met)
    fl = melody[met]
    print(fl.notes, fl.rhythm)

    // ternary condition to trigger event or not : rest, or event depending on trigger
    (met) ? _; osc_send(handle, "/csound/scheduler", mtof(80))
    (fl.rhythm) ? _; osc_send(handle, "/csound/scheduler", mtof(fl.notes))

    @(60s): {
        print("End of instance")
        stop
    }
}