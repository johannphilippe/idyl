// Test: catch system with emitted values
// A temporal function counts ticks and emits a 'done' trigger after 5 ticks.
// The catch handler fires when 'done' becomes truthy.

counter_with_end(dt=100ms) = count |> {
    init: { count = 0  emit done = _ }
    count = count + 1
    emit done = (count >= 5) ? _; !
}

process: {
    sig = counter_with_end()
    print(sig)
    catch sig::done: {
        print("Caught done! count =", sig)
        stop
    }
}
