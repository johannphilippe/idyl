base_dt = 100ms 
age_accumulator(dt=base_dt) = age
age_accumulator2(dt=base_dt) = x
|> {
    x = age
}
age_accumulator3(dt=base_dt) = x
|> {
    init: {x = age}
    x = age
}

// Oneshot: fire trigger only on the first tick (age == 0).
// Ternary semantics: (cond) ? false_branch ; true_branch
// (age == 0) is true (1) on first tick -> selects second option (!)
oneshot(dt=200ms) = (age == 0) ? _ ; !

process counting: {
    print(age_accumulator(), age_accumulator2(), age_accumulator3())
    print("accum1", age_accumulator() )
    print ("accum2" , age_accumulator2() )
    print ("accum3" , age_accumulator3() )
}

process oneshot_test: {
    t = oneshot()
    print("oneshot fired:", t)
}