/*
================================================================================
  IDYL LANGUAGE — COMPREHENSIVE SYNTAX REFERENCE
  
  This file progressively demonstrates all core features of the Idyl language,
  from the simplest to more complex examples.  Each section builds on previous
  concepts, making this suitable as a language tutorial.
  
  Status: Pre-Alpha v0.2
  Every line in this file passes semantic analysis and runs without error.
================================================================================
*/

// ============================================================================
// SECTION 1: COMMENTS
// ============================================================================

// This is a single-line comment — extends to the end of the line

/* This is a multi-line comment.
   It can span multiple lines and contain any text.
   The parser completely ignores all comments. */


// ============================================================================
// SECTION 2: CONSTANTS AND BASIC EXPRESSIONS
// ============================================================================

// Zero — canonical silence/no event
silence = 0

// Simple numeric constants
one = 1
pi_approx = 3.14159
ratio = 0.5

// Musical/temporal constants
concert_pitch = 440hz          // 440 Hertz (period: ~2.27ms)
short_delay = 100ms            // 100 milliseconds
long_duration = 2.5s           // 2.5 seconds (= 2500ms)
beat_timing = 4.0b             // 4 beats (tempo-dependent, uses main clock)

// BPM literal — new in v0.2 — converts to period in ms
quarter_note = 120bpm          // 120 BPM → 500ms period

// Predefined constants: pi, tau, euler are always available
circle = 2 * pi
full_circle = tau


// ============================================================================
// SECTION 3: SIMPLE SINGLE-PARAMETER FUNCTIONS
// ============================================================================

// Basic mathematical operations
square(x) = x * x
cube(x) = x * x * x
double(x) = x * 2
half(x) = x / 2

// Frequency conversions
midi_to_freq(midi_note) = 440 * (2.0 ^ ((midi_note - 69) / 12.0))

// Utility: Is this number positive?  (ternary: false_val; true_val ? cond)
is_positive(x) = 0; 1 ? (x > 0)

// Utility: Is this number in range?
in_range(x) = 0; 1 ? ((x >= 0) & (x <= 1))


// ============================================================================
// SECTION 4: MULTI-PARAMETER FUNCTIONS
// ============================================================================

// Basic arithmetic operations
add(a, b) = a + b
subtract(a, b) = a - b
multiply(a, b) = a * b
divide(a, b) = a / b

// Scale and offset
scale_and_offset(input, scale, offset) = (input * scale) + offset

// Linear blend/interpolation between two signals
blend(sig_a, sig_b, blend_factor) = 
    sig_a * (1 - blend_factor) + sig_b * blend_factor

// Normalize a value to 0..1 range
normalize(value, min_val, max_val) = 
    (value - min_val) / (max_val - min_val)


// ============================================================================
// SECTION 5: OPERATOR PRECEDENCE AND GROUPING
// ============================================================================

// Explicit grouping for clarity
add_then_multiply_a(x, y, z) = (x + y) * z

// Multiplication before addition (natural precedence)
add_then_multiply_b(x, y, z) = x + y * z

// Nested operations
complex_expr(a, b, c, d) = ((a + b) * c) / (d + 1)


// ============================================================================
// SECTION 6: TIME LITERALS AND TEMPORAL ARITHMETIC
// ============================================================================

// Time values are first-class citizens
quick_pulse = 50ms
steady_pulse = 200ms
song_bar = 2s
long_sustain = 5s

// Time arithmetic
sustain_with_tail = long_sustain + 500ms
double_duration = steady_pulse * 2
half_duration = song_bar / 2

// Time unit conversions
ms_value = 1000ms           // 1000 milliseconds
s_value = 1.0s              // 1 second (= 1000ms)
hz_value = 10hz             // 10 Hz (= 100ms period)
beat_value = 8.0b           // 8 beats (tempo-dependent)
bpm_value = 90bpm           // 90 BPM (= 666.67ms period)


// ============================================================================
// SECTION 7: PRIMITIVE LITERALS — TRIGGERS AND REST
// ============================================================================

// Trigger: an instantaneous event/pulse
pulse = !

// Rest: no event / silence
no_event = _

// Combinations
pulse_and_rest = pulse + no_event    // Just the pulse
rest_and_pulse = no_event + pulse    // Just the pulse


// ============================================================================
// SECTION 8: STRINGS
// ============================================================================

// String literals use double quotes
greeting = "hello idyl"
label = "output_1"

// Strings concatenate with +
full_name = "idyl" + " " + "lang"


// ============================================================================
// SECTION 9: CONDITIONAL EXPRESSIONS (TERNARY)
// ============================================================================

// Two-way selection: false_option; true_option ? condition
abs_value(x) = (0 - x); x ? (x >= 0)

// Safe division — return 0 if dividing by zero
safe_divide(a, b) = 0; (a / b) ? (b != 0)

// Select between two waveforms
waveform_select(is_sine, freq) = 
    sin(freq); cos(freq) ? is_sine

// Multi-way selection (wraps around) — all options must be valid expressions
// Use numeric constants for note frequencies (C4, D4, E4, F4, G4):
note_from_degree(degree) = 
    261; 293; 329; 349; 391 ? (degree % 5)

// State machine: select output based on state index
state_output(state, idle_val, attack_val, sustain_val) = 
    idle_val; attack_val; sustain_val ? state


// ============================================================================
// SECTION 10: BITWISE OPERATIONS
// ============================================================================

// Convert floats to integers for bitwise operations
int_a(x) = int(x)

// Bitwise AND
bitwise_and(x, y) = int_a(x) & int_a(y)

// Bitwise OR
bitwise_or(x, y) = int_a(x) | int_a(y)

// Bitwise XOR
bitwise_xor(x, y) = int_a(x) ^ int_a(y)

// Left shift (multiply by power of 2)
shift_left(x, bits) = int_a(x) << int_a(bits)

// Right shift (divide by power of 2)
shift_right(x, bits) = int_a(x) >> int_a(bits)

// Bitwise NOT
bitwise_not(x) = ~int_a(x)


// ============================================================================
// SECTION 11: FLOWS — SEQUENCES AND COLLECTIONS
// ============================================================================

// Simple flow: a list of values
simple_sequence = [1, 2, 3, 4, 5]

// Flow with arithmetic sequence
numbers_0_to_9 = [i = 0..9 : i]

// Flow with scaling
doubled_values = [i = 0..9 : i * 2]

// Flow with function application
squared_values = [i = 1..5 : square(i)]

// Flow with range and expression
harmonics(fundamental_freq) = 
    [harmonic = 1..8 : fundamental_freq * harmonic]

// Sine table for wavetable synthesis
sine_table(table_size) = 
    [i = 0..table_size - 1 : sin(i / table_size * 2 * pi)]

// Musical scale degrees (12-tone equal temperament)
chromatic_scale(root_freq) = 
    [semitone = 0..11 : root_freq * (2.0 ^ (semitone / 12.0))]


// ============================================================================
// SECTION 12: MULTI-MEMBER FLOWS
// ============================================================================

// A flow with multiple named members
// Parameters used in generators must be resolvable at evaluation time.
// Here we use a constant sustain level (0.7) as a concrete example.
sustain_lvl = 0.7
flow envelope_data(attack_time, decay_time, release_time) = {
    attack: [i = 0..100 : i / 100]
    decay: [i = 0..50 : sustain_lvl + (1 - sustain_lvl) * (1 - i / 50)]
    sustain: [sustain_lvl]
    release: [i = 0..100 : sustain_lvl * (1 - i / 100)]
}

// A flow representing musical intervals
flow interval_set = {
    unison: [1.0]
    major_third: [1.25]
    perfect_fifth: [1.5]
    octave: [2.0]
}


// ============================================================================
// SECTION 13: STATEFUL FUNCTIONS — LAMBDA BLOCKS (CLOCK-DRIVEN)
// ============================================================================

// Counter that increments on every clock tick (dt=10ms)
clock_counter(dt=10ms) = counter_value |> {
    init: { counter_value = 0 }
    counter_value = counter_value + 1
}

// Sawtooth oscillator: phase increases linearly then wraps
sawtooth_osc(frequency, dt=10ms) = phase |> {
    init: { phase = 0 }
    phase = fmod(phase + 1 / (frequency * (dt / 1000ms)), 1)
}

// Low-frequency oscillator (LFO) for modulation
// Return variable "modulation" must be initialized in init for first-tick access.
my_lfo(freq, amplitude, dt=10ms) = modulation |> {
    init: { phase = 0  modulation = 0 }
    modulation = amplitude * sin(phase * 2 * pi)
    phase = fmod(phase + 1 / (freq * (dt / 1000)), 1)
}

// Exponential smoother for control signals
smooth_control(input, smoothing_factor, dt=10ms) = smoothed |> {
    init: { state = 0 }
    smoothed = state
    state = state + (input - state) * smoothing_factor
}

// Envelope follower — tracks input amplitude with release
envelope_follower(input, attack_coeff, release_coeff, dt=10ms) = env_out |> {
    init: { env = 0 }
    env_out = env
    env = (env * release_coeff); (input * attack_coeff + env * (1 - attack_coeff)) ? (input > env)
}


// ============================================================================
// SECTION 14: STATEFUL FUNCTIONS — TRIGGER-DRIVEN
// ============================================================================

// Sample-and-hold: captures input when trigger fires
sample_hold(input, capture!) = held_value |> {
    init: { held_value = 0 }
    held_value = input
}

// Counter increments on each trigger pulse
trigger_counter(spike!) = count |> {
    init: { count = 0 }
    count = count + 1
}

// Seq selector: advances to next sequence element on trigger
seq_selector(elements, advance!) = current_element |> {
    init: { index = 0 }
    current_element = elements
    index = (index + 1)
}


// ============================================================================
// SECTION 15: HYBRID FUNCTIONS — TRIGGER + CLOCK
// ============================================================================

// Smart decay: triggers set to maximum, then continuously decays over time
decay_on_trigger(trigger!, decay_rate, dt=50ms) = level |> {
    init: { level = 0 }
    level = (0; 1 ? trigger) + level * (1 - decay_rate)
}

// Ducking envelope: responds to trigger with release over time
ducker(trigger!, release_ms, dt=10ms) = gate_out |> {
    init: { target = 0  current = 0 }
    gate_out = current
    target = (0; 1 ? trigger)
    current = target; current; current * (1 - release_ms / 1000) ? (0; 1 ? trigger)
}


// ============================================================================
// SECTION 16: EMIT — SIDE-CHANNEL OUTPUT FROM TEMPORAL FUNCTIONS
// ============================================================================

// Temporal functions can emit named values alongside their main output.
// Use `emit name = expr` in init (for defaults) and update sections.

// A counter that emits a "step" value each tick
step_counter(dt=100ms) = count |> {
    init: { count = 0  emit step = 0 }
    emit step = 3
    count = count + step
}

// A countdown that emits a "finished" trigger when complete
countdown(dt=100ms) = remaining |> {
    init: { remaining = 10  emit finished = _ }
    remaining = remaining - 1
    emit finished = _; ! ? (remaining == 0)
}


// ============================================================================
// SECTION 17: EMIT ACCESSOR — :: OPERATOR
// ============================================================================

// The :: operator reads emitted values from a temporal function instance.
// Given `a = some_temporal_fn()`, use `a::field` to read its emitted values.
// This is also used for module namespace access: `osc::sine(440hz)`.

// (Demonstrated in process blocks below — see Section 21)


// ============================================================================
// SECTION 18: FIRST-CLASS FUNCTIONS
// ============================================================================

// Functions are values.  You can store them in variables and pass them around.
// A function name used as an expression returns a function reference.

// Ternary selector chooses between functions:
wave_select(selector) = sin; cos ? selector

// The selected function can be called indirectly in a process block.
// (Demonstrated in Section 21)


// ============================================================================
// SECTION 19: CLOCK & TEMPO SYSTEM
// ============================================================================

// bpm is a time literal: 120bpm = 500ms period, 60bpm = 1000ms period
period_at_120 = 120bpm
period_at_60 = 60bpm

// tempo()            → query main clock BPM (default: 120)
// tempo(bpm_val)     → set main clock BPM, propagate to children
// tempo(handle, bpm) → set specific clock BPM, propagate to children

// clock(bpm_val)                → create clock bound to main (default parent)
// clock(bpm_val, parent=handle) → create clock bound to specific parent
// clock(bpm_val, parent=0)      → create free-running clock (no parent)

// bpm(handle)        → query BPM of a specific clock

// When a parent's BPM changes, children scale proportionally:
//   ratio = child_bpm / parent_bpm  (captured at creation time)
//   new_child_bpm = new_parent_bpm * ratio

// (Demonstrated in Section 21)


// ============================================================================
// SECTION 20: COMPOSITION AND HIGHER-ORDER PATTERNS
// ============================================================================

// Chain multiple transforms
chain_effects(input, scale1, offset1, scale2, offset2) = 
    scale_and_offset(scale_and_offset(input, scale1, offset1), scale2, offset2)

// Apply function to flow elements (use len, not length)
apply_to_flow(flow_input, scale_factor) = 
    [i = 0..len(flow_input) : flow_input[i] * scale_factor]

// Combine two flows element-wise
combine_flows(flow_a, flow_b) = 
    [i = 0..len(flow_a) : blend(flow_a[i], flow_b[i], 0.5)]


// ============================================================================
// SECTION 21: PROCESS BLOCKS — EXECUTABLE ENTRY POINTS
// ============================================================================

// Process blocks are the only code that actually runs.
// Everything above is definitions — they only execute when called from here.

// ── Basic output ───────────────────────────────────────────────
process basic_output: {
    output = 440hz
    print("output:", output)
}

// ── Stateful oscillator ────────────────────────────────────────
process oscillator_demo, dur=1s: {
    my_osc = my_lfo(5hz, 1.0, dt=10ms)
    modulated_freq = 440hz * (1 + my_osc * 0.1)
}

// ── Flow operations ────────────────────────────────────────────
process flow_ops: {
    scale = chromatic_scale(440)
    print("chromatic scale:", scale)
    print("scale length:", len(scale))
}

// ── First-class functions ──────────────────────────────────────
process func_select: {
    // Select a function dynamically
    func = wave_select(1)
    result = func(pi / 4)
    print("selected func result:", result)
}

// ── Emit accessor (:: operator) ────────────────────────────────
process emit_demo, dur=5s: {
    c = step_counter()
    print("count:", c, "step:", c::step)
    doubled_step = c::step * 2
    print("doubled:", doubled_step)
}

// ── Catch blocks — event handling ──────────────────────────────
process catch_demo, dur=3s: {
    timer = countdown()
    print("timer: ", timer)
    timer catch finished: {
        print("Countdown complete!")
    }
}

// ── Clock & tempo ──────────────────────────────────────────────
process clock_demo: {
    // Query default tempo
    print("default tempo:", tempo())

    // Create child clocks
    c1 = clock(60bpm)
    c2 = clock(90bpm)
    print("c1:", bpm(c1), "c2:", bpm(c2))

    // Change main to 240 → children scale proportionally
    // c1 ratio = 60/120 = 0.5  → new c1 = 240 * 0.5  = 120
    // c2 ratio = 90/120 = 0.75 → new c2 = 240 * 0.75 = 180
    tempo(240bpm)
    print("after 240bpm: c1:", bpm(c1), "c2:", bpm(c2))

    // Hierarchical: c3 is child of c1
    c3 = clock(30bpm, parent=c1)

    // Free-running clock: unaffected by main
    c_free = clock(100bpm, parent=0)
    tempo(300bpm)
    print("c_free still:", bpm(c_free))
}


// ============================================================================
// END OF SYNTAX REFERENCE
// ============================================================================

/*
This file demonstrates the core features of Idyl v0.2-pre-alpha:

✓ Comments (single-line and multi-line)
✓ Constants and literals (numbers, time, triggers, strings)
✓ Time units: ms, s, hz, b, bpm
✓ Simple functions (single and multiple parameters)
✓ Default parameters (dt= for temporal, named args for any)
✓ Conditional expressions (ternary selection)
✓ Bitwise operations
✓ Flows (sequences with generators)
✓ Multi-member flows
✓ Stateful functions with lambda blocks (clock-driven)
✓ Trigger-driven stateful functions
✓ Hybrid trigger+clock functions
✓ Emit — side-channel output from temporal functions
✓ Emit accessor — :: operator to read emitted values
✓ First-class functions (function references, indirect calls)
✓ Clock & tempo system (hierarchy, propagation, bpm literal)
✓ Process blocks (executable entry points)
✓ Catch blocks (emit-based event handling)
✓ Function composition and higher-order patterns
*/
