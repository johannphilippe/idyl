lib("stdlib")
flow pattern(i) = {
    notes: [40+i, 42+i, 60+i, 62+i]
    rhythm: [!, _, !, !]
}

flow incr_pattern = [2, 12, 24]

flow gen_pattern(i) = [n = 1..4: 50 + n + i]

functional(i) = [n = 1..4: 50 + n + i]


process: {
    m1 = counter(dt=1s)
    m2 = metro(dt=0.3s)
    i = incr_pattern[m1]
    print(m1, i)

    //print(m1, i)
    //m = gen_pattern(i)[m2]
    pat = gen_pattern(i)
    m = pat[m2]
    print(m)
}