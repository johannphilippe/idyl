module("csound")
lib("stdlib")

handle = cs_open("csound_module.csd")

flow melody = {
    notes: [50 53 60 65 47 33 20]
    rhythm: [! ! _ ! ! ! _ _ _ ! _ ! ! !]
}

note(spike!, note) = cs_note(handle, "first", d, 0.3, note)
|> {
    d = as_s(rnd(0.5, 4))
}

process: {
    met = metro(dt = 0.1s)
    print(met)
    fl = melody[met]
    print(fl.notes, fl.rhythm)

    a = note(fl.rhythm, mtof(fl.notes + 12))

    b = note(met, mtof(83) )

    @(60s): {
        print("End of instance")
        stop
    }
}