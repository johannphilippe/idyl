module("csound")
lib("stdlib")

handle = cs_open("csound_module.csd")

flow melody(i) = {
    notes: [50+i 53+i 60+i 65+i 47+i 33+i 20+i]
    rhythm: [! ! _ ! ! ! _ _ _ ! _ ! ! !]
}

flow incr = [12 -12]

note(spike!, note) = cs_note(handle, "first", 0.3s, 0.3, note)

process: {
    m1 = metro(dt=3s)
    i = incr[m1]

    met = metro(dt = 0.3s)
    print(met)
    fl = melody[met]
    print(fl.notes, fl.rhythm)

    a = note(fl.rhythm, mtof(fl.notes + 12))

    b = note(met, mtof(83) )

    @(60s): {
        print("End of instance")
        stop
    }
}